      </ul>
    </p>

    <p>Test Yourself</p>
    <p>R Functions Used in This Chapter</p>
    <tabular>
      <row><cell><c>c()</c></cell><cell>Concatenates data elements together</cell></row>
      <row><cell><c>&lt;-</c></cell><cell>Assignment arrow</cell></row>
      <row><cell><c>sum()</c></cell><cell>Adds data elements</cell></row>
      <row><cell><c>range()</c></cell><cell>Max value minus min value</cell></row>
      <row><cell><c>mean()</c></cell><cell>The average</cell></row>
    </tabular>
  </conclusion>

</chapter>
